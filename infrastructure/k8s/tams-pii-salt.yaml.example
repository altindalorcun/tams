apiVersion: v1
kind: Secret
metadata:
  name: tams-pii-salt
  namespace: tams
  labels:
    app.kubernetes.io/part-of: tams
type: Opaque
stringData:
  # Secret salt used by parser-service to deterministically hash TC Kimlik No and Öğrenci No.
  # Generate with: openssl rand -hex 64
  # WARNING: Once set and transcripts have been processed, this value must never change.
  # Changing it makes all existing masked_student_ref values impossible to correlate.
  PII_HASH_SALT: CHANGE_ME_MINIMUM_64_HEX_CHARS
