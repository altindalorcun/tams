# parser-service environment configuration
# Copy to .env for local development. Never commit real secrets.

# --- HTTP server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=parser-service
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_TOPIC_RAW=transcript.raw
KAFKA_TOPIC_PARSED=transcript.parsed

# Set to false to run the HTTP server without the Kafka consumer loop.
ENABLE_CONSUMER=true
