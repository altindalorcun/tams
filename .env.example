# ============================================================================
# TAMS — Environment Variables
# Copy this file to .env and fill in real values. Never commit .env.
#
# To generate a Kafka Cluster ID (required once per cluster):
#   docker run --rm confluentinc/cp-kafka:7.8.0 kafka-storage random-uuid
# ============================================================================


# ─── Kafka ──────────────────────────────────────────────────────────────────

# Base64-encoded 22-char UUID. Generate once and keep stable across restarts.
KAFKA_CLUSTER_ID=REPLACE_WITH_BASE64_KAFKA_CLUSTER_ID

KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW=transcript.raw
KAFKA_TOPIC_PARSED=transcript.parsed


# ─── PostgreSQL — auth-service ───────────────────────────────────────────────

POSTGRES_AUTH_HOST=postgres-auth
POSTGRES_AUTH_PORT=5432
POSTGRES_AUTH_DB=tams_auth
POSTGRES_AUTH_USER=tams_auth_user
POSTGRES_AUTH_PASSWORD=REPLACE_WITH_STRONG_PASSWORD


# ─── PostgreSQL — rule-service ───────────────────────────────────────────────

POSTGRES_RULES_HOST=postgres-rules
POSTGRES_RULES_PORT=5432
POSTGRES_RULES_DB=tams_rules
POSTGRES_RULES_USER=tams_rules_user
POSTGRES_RULES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD


# ─── PostgreSQL — analysis-service ──────────────────────────────────────────

POSTGRES_ANALYSIS_HOST=postgres-analysis
POSTGRES_ANALYSIS_PORT=5432
POSTGRES_ANALYSIS_DB=tams_analysis
POSTGRES_ANALYSIS_USER=tams_analysis_user
POSTGRES_ANALYSIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD


# ─── JWT ─────────────────────────────────────────────────────────────────────

# Minimum 256-bit (32-byte) random secret for HMAC-SHA256.
# Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_WITH_BASE64_JWT_SECRET

# Access token TTL in milliseconds (default: 15 minutes)
JWT_ACCESS_EXPIRATION_MS=900000

# Refresh token TTL in milliseconds (default: 7 days)
JWT_REFRESH_EXPIRATION_MS=604800000


# ─── PII Masking ─────────────────────────────────────────────────────────────

# Salt used by parser-service when hashing TC Kimlik No and Öğrenci No.
# Generate with: openssl rand -base64 32
# Must NEVER be empty or changed after first use (existing hashes would no longer match).
PII_HASH_SALT=REPLACE_WITH_RANDOM_SALT


# ─── Admin seed credentials ───────────────────────────────────────────────────

# auth-service creates this admin account on first startup via ApplicationRunner.
ADMIN_SEED_EMAIL=admin@tams.local
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD


# ─── Service ports (host-mapped, Docker Compose only) ─────────────────────────

API_GATEWAY_PORT=8080
AUTH_SERVICE_PORT=8081
RULE_SERVICE_PORT=8082
ANALYSIS_SERVICE_PORT=8083
PARSER_SERVICE_PORT=8084
FRONTEND_PORT=5173

# Host-mapped PostgreSQL ports (for direct DB access from host, e.g. DBeaver)
POSTGRES_AUTH_HOST_PORT=5432
POSTGRES_RULES_HOST_PORT=5433
POSTGRES_ANALYSIS_HOST_PORT=5434


# ─── Service URLs (used by api-gateway and analysis-service) ──────────────────

AUTH_SERVICE_URL=http://auth-service:8081
RULE_SERVICE_URL=http://rule-service:8082
ANALYSIS_SERVICE_URL=http://analysis-service:8083

# Frontend — must match the host from which the browser loads the app
VITE_API_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173
